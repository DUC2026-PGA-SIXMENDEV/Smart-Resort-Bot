TELEGRAM_BOT_TOKEN=
ADMIN_IDS=
RESORT_NAME=Paradise Resort & Spa

# Google Sheets
GOOGLE_SHEETS_NAME=Resort Bookings
GOOGLE_SHEETS_CREDS=credentials.json
# On Render, paste the full service-account JSON into this secret env var instead
# of committing credentials.json.
GOOGLE_SHEETS_CREDS_JSON=
AVAILABILITY_REFRESH_SECONDS=60

# Render webhook mode. Set WEBHOOK_URL to your Render service URL:
# https://your-service-name.onrender.com
WEBHOOK_URL=
WEBHOOK_PATH=telegram
DROP_PENDING_UPDATES=false
